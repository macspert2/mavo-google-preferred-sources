msgid "Use the shortcode below to place the button manually anywhere in your content:"
msgstr "Use the shortcode below to place the button manually anywhere in your content:"

msgid "<strong>Important:</strong> Your site must be listed in Google's source-preferences tool before this button has any effect. <a href=\"https://www.google.com/preferences/source\" target=\"_blank\" rel=\"noopener\">Check if your domain appears there ↗</a>"
msgstr "<strong>Important:</strong> Your site must be listed in Google's source-preferences tool before this button has any effect. <a href=\"https://www.google.com/preferences/source\" target=\"_blank\" rel=\"noopener\">Check if your domain appears there ↗</a>"

msgid "Google only supports domain-level sources — <strong>subdirectories are not eligible</strong>. Use the bare registered domain (e.g. <code>example.com</code>). <a href=\"https://www.google.com/preferences/source\" target=\"_blank\" rel=\"noopener\">Verify your domain is listed on Google ↗</a>"
msgstr "Google only supports domain-level sources — <strong>subdirectories are not eligible</strong>. Use the bare registered domain (e.g. <code>example.com</code>). <a href=\"https://www.google.com/preferences/source\" target=\"_blank\" rel=\"noopener\">Verify your domain is listed on Google ↗</a>"
